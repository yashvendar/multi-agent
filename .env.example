# ─── Google Cloud (ADC — no API key needed) ────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Model selection ────────────────────────────────────────────────────────
SUPERVISOR_MODEL=gemini-2.0-flash
SUBAGENT_MODEL=gemini-2.5-pro

# ─── Sub-agent databases (READ-ONLY) ────────────────────────────────────────
KPI_DB_DSN=postgresql://user:pass@host:5432/kpi_db
KPI_DB_SCHEMAS=kpi_config,kpi_values

IOT_DB_DSN=postgresql://user:pass@host:5432/iot_db
IOT_DB_SCHEMAS=public,iot_data

ASSET_DB_DSN=postgresql://user:pass@host:5432/asset_db
ASSET_DB_SCHEMAS=public,asset_data


# ─── Conversation database (READ + WRITE) ───────────────────────────────────
CONV_DB_DSN=postgresql://user:pass@host:5432/conversation_db

# ─── Docs / vector database (pgvector) ──────────────────────────────────────
# Leave blank to reuse CONV_DB_DSN (the agent_docs table is auto-created there)
DOCS_DB_DSN=postgresql://user:pass@host:5432/conversation_db

# ─── Federated database (READ-ONLY, for supervisor cross-domain queries) ────
FEDERATED_DB_DSN=postgresql://user:pass@host:5432/federated_db

# ─── Embedding model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=models/text-embedding-004

# ─── Confluence ──────────────────────────────────────────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=you@yourcompany.com
CONFLUENCE_API_TOKEN=your_atlassian_api_token

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
